# ~/.codex/secrets/evm-rpc-providers.env first, then falls back to public RPC.
# BSC_RPC_URL=https://bsc-dataseed.binance.org

# Keep real keys only in .env, never in docs or chat.
# PRIVATE_KEY=0x...
